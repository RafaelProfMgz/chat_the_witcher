# ============================================
# 🐺 WITCHER ORACLE - Variáveis de Ambiente
# ============================================
# ⚠️  ESTE ARQUIVO É UM TEMPLATE PÚBLICO
# ⚠️  Copie este arquivo para .env.local e preencha com suas chaves reais
#
#     cp .env.example .env.local
#
# ⚠️  NUNCA commitar o arquivo .env.local!
# ============================================

# ------------------------------------------
# 🔑 Google Gemini API Key (Gratuita)
# ------------------------------------------
# A chave de API do Google Gemini é necessária para o funcionamento do chat IA.
# Você pode obter uma gratuitamente em:
#   https://aistudio.google.com/app/apikey
#
# Passos:
#   1. Acesse o link acima e faça login com sua conta Google
#   2. Clique em "Create API Key"
#   3. Copie a chave gerada e cole abaixo
#
GEMINI_API_KEY=your_gemini_api_key_here

# ------------------------------------------
# 🎮 Configurações do App
# ------------------------------------------
# Nome público do aplicativo (visível no frontend)
NEXT_PUBLIC_APP_NAME=Witcher Oracle

# Descrição do aplicativo (usada em meta tags e UI)
NEXT_PUBLIC_APP_DESCRIPTION=O Oráculo do Bruxo - Chat IA sobre The Witcher 3
